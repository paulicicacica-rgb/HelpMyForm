{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "helpmyform.com" }],
      "destination": "https://www.helpmyform.com/:path*",
      "permanent": true
    }
  ]
}
